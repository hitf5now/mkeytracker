##
## M+ Platform — environment template
## Copy to .env for local dev. Never commit .env.
##

# ─── Database (local docker-compose) ───────────────────────────────
# Host port exposed by local docker-compose.yml
DATABASE_URL="postgresql://mplus:mplus_dev_password@localhost:5432/mplus_platform?schema=public"

# ─── Redis (local docker-compose) ─────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ──────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="debug"

# Secret used by the companion app to exchange a short-lived /auth/link
# code for a long-lived JWT. Also signs inbound JWTs.
JWT_SECRET="change-me-32-bytes-minimum-xxxxxxxxxxxxxx"

# Shared secret between API and Discord bot for bot→API internal calls.
API_INTERNAL_SECRET="change-me-bot-to-api-shared-secret"

# ─── Discord Bot ──────────────────────────────────────────────────
# From discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN="your-bot-token-here"
# From General Information → Application ID
DISCORD_CLIENT_ID="your-application-id"
# Right-click your dev server → Copy Server ID (requires Developer Mode)
# When set, slash commands register instantly to this guild only.
# Leave empty in prod to register globally.
DISCORD_GUILD_ID="your-dev-server-id"

# Discord webhook URLs for channel announcements (optional for Sprint 1)
DISCORD_WEBHOOK_RESULTS=""
DISCORD_WEBHOOK_EVENTS=""

# ─── RaiderIO (no auth required for public endpoints) ────────────
RAIDERIO_BASE_URL="https://raider.io/api/v1"

# ─── Production-only (leave blank in .env) ───────────────────────
# Set in Unraid container env, not locally.
# PUBLIC_API_URL="https://api.hitf5now.com"
