{
  "name": "@mplus/combat-log-parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Streaming parser for WoWCombatLog.txt — extracts Mythic+ run summaries with per-player damage/healing/interrupts/deaths.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "mplus-parse-log": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "summarize": "tsx src/cli.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
