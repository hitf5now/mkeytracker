{
  "name": "@mplus/combat-log-parser",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Streaming parser for WoWCombatLog.txt — extracts Mythic+ run summaries with per-player damage/healing/interrupts/deaths.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "bin": {
    "mplus-parse-log": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "summarize": "tsx src/cli.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
