//
// M+ Platform — Prisma schema
//
// Sprint 1 scope: reference data, identity, runs.
// Later sprints will add events, scoring, leaderboards, badges, mentorship.
//
// Naming convention:
//   - snake_case for database columns/tables (@@map, @map)
//   - camelCase for Prisma/TypeScript
//

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Reference data
// ─────────────────────────────────────────────────────────────

model Season {
  id       Int       @id @default(autoincrement())
  /// Short slug, e.g. "midnight-s1"
  slug     String    @unique
  /// Display name, e.g. "Midnight Season 1"
  name     String
  /// WoW patch this season corresponds to, e.g. "12.0.0"
  patch    String
  startsAt DateTime  @map("starts_at")
  endsAt   DateTime? @map("ends_at")
  isActive Boolean   @default(false) @map("is_active")

  dungeons           Dungeon[]
  runs               Run[]
  events             Event[]
  teams              Team[]
  endorsements       Endorsement[]
  seasonalTokenUsers User[]        @relation("seasonalTokens")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("seasons")
}

model Dungeon {
  id              Int    @id @default(autoincrement())
  /// WoW internal challenge_mode_id used by C_ChallengeMode API
  challengeModeId Int    @map("challenge_mode_id")
  /// Short slug, e.g. "halls-of-atonement"
  slug            String
  name            String
  /// Par time in seconds — used for on_time calculation and scoring
  parTimeSec      Int    @map("par_time_sec")
  /// Short 3-5 letter abbreviation for compact leaderboard display
  shortCode       String @map("short_code")

  seasonId Int    @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id])

  runs   Run[]
  events Event[]

  @@unique([seasonId, challengeModeId])
  @@unique([seasonId, slug])
  @@map("dungeons")
}

// ─────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────

model User {
  id             Int            @id @default(autoincrement())
  /// Discord user snowflake — primary identity anchor
  discordId      String         @unique @map("discord_id")
  /// Opt-in BattleTag for cross-realm group formation
  battleTag      String?        @map("battle_tag")
  /// IANA timezone, e.g. "America/New_York"
  timezone       String?
  /// Mentor program opt-in
  isMentor       Boolean        @default(false) @map("is_mentor")
  mentorJuice    Int            @default(0) @map("mentor_juice")
  /// Where the bot should post this user's run-completed embeds.
  /// See RunResultsMode docs.
  runResultsMode RunResultsMode @default(all_my_servers) @map("run_results_mode")

  /// Rolling counter of all Personal Juice ever earned. Drives endorsement
  /// token minting: floor(lifetimeJuiceEarned / 15000) = tokens ever owed.
  lifetimeJuiceEarned     Int     @default(0) @map("lifetime_juice_earned")
  /// How many Juice-derived tokens we've already minted for this user.
  /// Idempotency guard: newTokens = floor(lifetimeJuiceEarned/15000) - tokensGrantedFromJuice
  tokensGrantedFromJuice  Int     @default(0) @map("tokens_granted_from_juice")
  /// Tokens from one-time starter-pack grants (Discord login, companion link).
  /// Persists across seasons. Spent last (seasonal spent first, use-it-or-lose-it).
  starterTokensRemaining  Int     @default(0) @map("starter_tokens_remaining")
  /// Tokens earned from Juice this season. Zeroed at season rollover.
  seasonalTokensRemaining Int     @default(0) @map("seasonal_tokens_remaining")
  /// Which season seasonalTokensRemaining belongs to. If != current active
  /// season when touched, reset to 0 and rebind before grant/spend.
  seasonalTokensSeasonId  Int?    @map("seasonal_tokens_season_id")
  seasonalTokensSeason    Season? @relation("seasonalTokens", fields: [seasonalTokensSeasonId], references: [id])
  /// Flag: starter grant for completing Discord login has been issued.
  starterDiscordGranted   Boolean @default(false) @map("starter_discord_granted")
  /// Flag: starter grant for linking the companion app has been issued.
  starterCompanionGranted Boolean @default(false) @map("starter_companion_granted")

  /// User-pinned favorite endorsement (optional). Shown at top of profile.
  favoriteEndorsementId Int?         @unique @map("favorite_endorsement_id")
  favoriteEndorsement   Endorsement? @relation("favoriteEndorsement", fields: [favoriteEndorsementId], references: [id], onDelete: SetNull)

  characters           Character[]
  runMembers           RunMember[]
  eventSignups         EventSignup[]
  eventsCreated        Event[]               @relation("eventsCreated")
  teamsCaptained       Team[]                @relation("teamsCaptained")
  serverAdminships     DiscordServerAdmin[]
  serverMemberships    DiscordServerMember[]
  endorsementsGiven    Endorsement[]         @relation("endorsementsGiven")
  endorsementsReceived Endorsement[]         @relation("endorsementsReceived")
  readyChecksStarted   ReadyCheck[]          @relation("readyChecksStarted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Character {
  id           Int     @id @default(autoincrement())
  name         String
  /// Realm slug, lowercase-hyphenated, e.g. "area-52"
  realm        String
  /// us, eu, kr, tw, cn
  region       String
  /// WoW class slug, e.g. "shaman". This is permanent for the character —
  /// a shaman is always a shaman. Join with packages/wow-constants to
  /// resolve display name, color, and valid specs/roles.
  class        String
  /// DEFAULT spec. The character's last-known active spec from RaiderIO
  /// or manual refresh. This is just a hint — NOT a constraint. Players
  /// pick their actual role per event at signup time, and the addon
  /// records what was actually played into run_members.spec_snapshot.
  spec         String
  /// DEFAULT role, matching the default spec. Same caveat as `spec`.
  role         String
  /// Latest RaiderIO overall score — refreshed on submission + nightly
  rioScore     Int     @default(0) @map("rio_score")
  /// Character portrait URLs (cached from RaiderIO + Blizzard API)
  thumbnailUrl String? @map("thumbnail_url") // 96x96 avatar (from RaiderIO)
  avatarUrl    String? @map("avatar_url") // 96x96 from Blizzard CDN
  insetUrl     String? @map("inset_url") // ~460x460 bust render from Blizzard CDN
  mainRawUrl   String? @map("main_raw_url") // ~1000x1000 full body transparent PNG

  /// Nullable: an "unclaimed" character exists in our DB because someone
  /// else ran a key with them. When the actual player registers via the
  /// Discord bot, /register will claim the row by setting userId.
  userId    Int?      @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Timestamp when this character was claimed by a registered user.
  /// NULL until /register links it.
  claimedAt DateTime? @map("claimed_at")

  /// True if this character has submitted at least one run via the
  /// companion app. Used by matchmaking (prefer 1 per group) and as
  /// a subtle tag in embeds/web (⚡ icon).
  hasCompanionApp Boolean @default(false) @map("has_companion_app")

  runMembers           RunMember[]
  eventSignups         EventSignup[]
  teamMembers          TeamMember[]
  runEnrichmentPlayers RunEnrichmentPlayer[]
  endorsementsGivenByCharacter    Endorsement[] @relation("endorsementsGivenByCharacter")
  endorsementsReceivedByCharacter Endorsement[] @relation("endorsementsReceivedByCharacter")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// A WoW character is unique by (name, realm, region)
  @@unique([region, realm, name])
  @@index([userId])
  @@map("characters")
}

// ─────────────────────────────────────────────────────────────
// Runs
// ─────────────────────────────────────────────────────────────

enum RunSource {
  addon
  manual
  raiderio
}

/// Where the bot should announce a user's completed runs.
/// - all_my_servers: every Discord server the user is a member of (default)
/// - none: never post the user's runs to any server
/// - primary: post only to the server marked DiscordServerMember.isPrimary
enum RunResultsMode {
  all_my_servers
  none
  primary
}

model Run {
  id            Int         @id @default(autoincrement())
  dungeonId     Int         @map("dungeon_id")
  seasonId      Int         @map("season_id")
  keystoneLevel Int         @map("keystone_level")
  completionMs  Int         @map("completion_ms")
  parMs         Int         @map("par_ms")
  onTime        Boolean     @map("on_time")
  /// Keystone upgrade level: 0 (depleted/no upgrade), 1 (+1), 2 (+2), 3 (+3)
  upgrades      Int         @default(0)
  deaths        Int         @default(0)
  timeLostSec   Int         @default(0) @map("time_lost_sec")
  /// Active affix ids from C_MythicPlus.GetCurrentAffixes()
  affixes       Int[]       @default([])
  /// Unix seconds at run completion, from the WoW server
  serverTime    BigInt      @map("server_time")
  /// When the API received the run
  recordedAt    DateTime    @default(now()) @map("recorded_at")
  source        RunSource   @default(addon)
  /// True after RaiderIO cross-verification job confirms this run
  verified      Boolean     @default(false)
  /// Dedup hash — see services/run-dedup.ts
  dedupHash     String      @unique @map("dedup_hash")
  /// Personal Juice — computed by scoring service on insert
  personalJuice Int         @default(0) @map("personal_juice")
  /// Event Juice — only set when run is linked to an event
  eventJuice    Int?        @map("event_juice")
  /// Team Juice — set when all 5 party members share a team
  teamJuice     Int?        @map("team_juice")
  /// Dynamic dungeon name from addon (used for auto-discovery)
  dungeonName   String?     @map("dungeon_name")
  /// WoW season ID (dynamic, from C_MythicPlus.GetCurrentSeason)
  wowSeasonId   Int?        @map("wow_season_id")
  /// Submitter's M+ rating before this run
  oldRating     Int?        @map("old_rating")
  /// Submitter's M+ rating after this run
  newRating     Int?        @map("new_rating")
  /// Rating gained from this run
  ratingGained  Int?        @map("rating_gained")
  /// Personal best flags
  isMapRecord   Boolean     @default(false) @map("is_map_record")
  isAffixRecord Boolean     @default(false) @map("is_affix_record")
  /// Per-player combat stats (JSON: { "Name-realm": { damage, healing, deaths, interrupts, ... } })
  playerStats   Json?       @map("player_stats")
  /// Optional event association
  eventId       Int?        @map("event_id")
  event         Event?      @relation(fields: [eventId], references: [id])
  groupId       Int?        @map("group_id")
  eventGroup    EventGroup? @relation(fields: [groupId], references: [id])

  dungeon      Dungeon          @relation(fields: [dungeonId], references: [id])
  season       Season           @relation(fields: [seasonId], references: [id])
  members      RunMember[]
  runEvents    RunEvent[]
  discordPosts RunDiscordPost[]
  endorsements Endorsement[]
  /// Combat-log enrichment from the companion app's WoWCombatLog.txt parser.
  /// Optional: populated when the companion is running, ACL is enabled, and a
  /// matching log segment was found. Runs are still valid without it.
  enrichment   RunEnrichment?

  @@index([seasonId, dungeonId, completionMs])
  @@index([seasonId, keystoneLevel])
  @@index([recordedAt])
  @@index([eventId])
  @@map("runs")
}

/// Tracks which Discord channels have already received a run-completed embed
/// for a given run. The bot consults this table before posting so a single
/// run is never broadcast twice to the same channel, even when multiple
/// party members submit it via the companion app.
model RunDiscordPost {
  id        Int      @id @default(autoincrement())
  runId     Int      @map("run_id")
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// Discord channel snowflake the embed was posted to.
  channelId String   @map("channel_id")
  postedAt  DateTime @default(now()) @map("posted_at")

  @@unique([runId, channelId])
  @@index([runId])
  @@map("run_discord_posts")
}

// ─────────────────────────────────────────────────────────────
// Events — organized M+ competitions
// ─────────────────────────────────────────────────────────────

enum EventStatus {
  draft // created but not yet visible to players
  open // Spec: "Posted". Embed published, signups accepted, Ready Check not yet available.
  in_progress // RC available; signups stay open throughout
  completed // event finished, results final
  cancelled // scrapped before completion
}

/// Ready Check lifecycle state for a formed group.
/// - forming: created by an RC; can still vote-disband or auto-timeout
/// - matched: a run was associated (terminal)
/// - disbanded: 2 members voted to disband (terminal)
/// - timed_out: reached 2h idle or event end with no run (terminal)
enum EventGroupState {
  forming
  matched
  disbanded
  timed_out
}

/// Flex role declared on signup. "none" is a valid first-class answer —
/// not the same as null.
enum FlexRole {
  tank
  healer
  dps
  none
}

/// Which of the 5 skeleton seats a signup occupies within a group.
/// Null = not assigned to any group. Each (groupId, slotPosition) is unique.
enum SlotPosition {
  tank
  healer
  dps1
  dps2
  dps3
}

enum ReadyCheckState {
  active
  expired
}

enum EventType {
  fastest_clear_race // All groups, same dungeon, fastest timed clear wins
  speed_sprint // 30-min window, single attempt per group
  random_draft // Bot assembles random role-balanced groups
  key_climbing // Push highest key possible, peak level wins
  marathon // Most runs in time window, accumulated score wins
  best_average // Best average score across top N runs
  bracket_tournament // Single-elimination bracket, head-to-head matchups
}

enum EventMode {
  group // Individual signup + auto-matchmaking into groups
  team // Pre-made team signup (no matchmaking)
}

/// How the signup was created
enum SignupSource {
  discord_verified // user has a linked Character, clicked button
  discord_manual // user entered character info via modal
  web_oauth // signed up through website
}

/// Signup intent status
enum SignupStatus {
  confirmed // definitely attending
  tentative // interested but unsure
  declined // not attending (tracked for analytics)
}

model Event {
  id         Int         @id @default(autoincrement())
  name       String
  type       EventType   @default(fastest_clear_race)
  mode       EventMode   @default(group)
  status     EventStatus @default(draft)
  /// Type-specific config (e.g., runsToCount for best_average)
  typeConfig Json?       @map("type_config")

  /// Discord message ID of the event embed (for in-place updates)
  discordMessageId String? @map("discord_message_id")
  /// Discord channel ID where the embed was posted
  discordChannelId String? @map("discord_channel_id")

  /// Which dungeon this event targets (null = any dungeon)
  dungeonId Int?     @map("dungeon_id")
  dungeon   Dungeon? @relation(fields: [dungeonId], references: [id])

  seasonId Int    @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id])

  /// Discord server this event belongs to
  serverId       Int?           @map("server_id")
  server         DiscordServer? @relation(fields: [serverId], references: [id])
  /// Legacy: Discord guild snowflake (kept for backcompat during migration)
  discordGuildId String?        @map("discord_guild_id")

  /// Key level constraints for the event
  minKeyLevel Int @default(2) @map("min_key_level")
  maxKeyLevel Int @default(40) @map("max_key_level")

  /// Signup window
  signupOpensAt  DateTime? @map("signup_opens_at")
  signupClosesAt DateTime? @map("signup_closes_at")

  /// Event run window
  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")

  /// Who created this event
  createdByUserId Int  @map("created_by_user_id")
  createdByUser   User @relation("eventsCreated", fields: [createdByUserId], references: [id])

  /// Optional description / rules text
  description String?

  signups      EventSignup[]
  groups       EventGroup[]
  teamSignups  TeamEventSignup[]
  runs         Run[]
  runEvents    RunEvent[]        @relation("eventRuns")
  readyChecks  ReadyCheck[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([seasonId])
  @@index([startsAt])
  @@index([discordGuildId])
  @@map("events")
}

model EventSignup {
  id      Int   @id @default(autoincrement())
  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  /// Nullable: unverified manual signups may not have a User row.
  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id])

  /// Discord user snowflake of whoever clicked the button / submitted.
  /// Primary identity key for signups — used for dedup since userId can be null.
  discordUserId String? @map("discord_user_id")

  characterId Int       @map("character_id")
  character   Character @relation(fields: [characterId], references: [id])

  /// The role this player wants to fill for this event. Validated
  /// against packages/wow-constants at signup time — a mage can't
  /// sign up as tank.
  rolePreference String @map("role_preference") // "tank" | "healer" | "dps"

  /// Secondary role the player is willing to flex to. "none" = player does
  /// not want to flex. Flex is only pulled by matchmaking when doing so
  /// unlocks an additional complete skeleton (see design spec §6.3).
  flexRole FlexRole @default(none) @map("flex_role")

  /// Set on a signup that participated in a Ready Check but was not
  /// assigned to any group (solo, insufficient roles, bounced leftover).
  /// Cleared on next assignment OR when the event transitions to completed.
  priorityFlag Boolean @default(false) @map("priority_flag")

  /// The spec the player chose for this event. Always user-selected,
  /// never auto-set. Role is derived from spec.
  spec String?

  /// How this signup was created
  signupSource SignupSource @default(discord_verified) @map("signup_source")

  /// Signup intent: confirmed, tentative, or declined
  signupStatus SignupStatus @default(confirmed) @map("signup_status")

  /// Which group is this signup assigned to? Null until a Ready Check expires
  /// and places them into a skeleton. Groups are ephemeral per RC.
  groupId Int?        @map("group_id")
  group   EventGroup? @relation(fields: [groupId], references: [id])

  /// Which of the 5 skeleton seats this signup occupies within its group.
  /// Null when groupId is null. A partial unique index on (group_id,
  /// slot_position) WHERE slot_position IS NOT NULL enforces that each seat
  /// is held by at most one signup; that constraint lives in the migration
  /// SQL rather than here because Prisma can't express partial uniques.
  slotPosition SlotPosition? @map("slot_position")

  readyCheckParticipants ReadyCheckParticipant[]

  signedUpAt DateTime @default(now()) @map("signed_up_at")

  @@unique([eventId, discordUserId])
  @@index([eventId])
  @@map("event_signups")
}

model EventGroup {
  id      Int   @id @default(autoincrement())
  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  /// Display name, e.g. "Group 1", auto-generated at RC expiry.
  name String

  /// Lifecycle state. See EventGroupState for semantics.
  state EventGroupState @default(forming)

  /// The Ready Check that produced this group. Null only for legacy rows
  /// pre-dating the RC system.
  readyCheckId Int?        @map("ready_check_id")
  readyCheck   ReadyCheck? @relation(fields: [readyCheckId], references: [id])

  members   EventSignup[]
  runs      Run[]
  runEvents RunEvent[]

  assignedAt DateTime @default(now()) @map("assigned_at")
  /// Set when state transitions out of `forming`.
  resolvedAt DateTime? @map("resolved_at")

  @@index([eventId])
  @@index([state])
  @@map("event_groups")
}

// ─────────────────────────────────────────────────────────────
// Ready Check — the group-forming mechanism (see design spec §5)
// ─────────────────────────────────────────────────────────────

model ReadyCheck {
  id      Int   @id @default(autoincrement())
  eventId Int   @map("event_id")
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  startedAt DateTime @default(now()) @map("started_at")
  /// 5 minutes after startedAt by default; scheduler expires at this mark.
  expiresAt DateTime @map("expires_at")

  state ReadyCheckState @default(active)

  /// Who clicked first — used for display and audit.
  startedByUserId Int  @map("started_by_user_id")
  startedByUser   User @relation("readyChecksStarted", fields: [startedByUserId], references: [id])

  participants ReadyCheckParticipant[]
  /// Groups produced when this RC expired. Zero if formation found no valid skeleton.
  groups       EventGroup[]

  @@index([eventId, state])
  @@map("ready_checks")
}

model ReadyCheckParticipant {
  id           Int        @id @default(autoincrement())
  readyCheckId Int        @map("ready_check_id")
  readyCheck   ReadyCheck @relation(fields: [readyCheckId], references: [id], onDelete: Cascade)
  signupId     Int        @map("signup_id")
  signup       EventSignup @relation(fields: [signupId], references: [id], onDelete: Cascade)

  joinedAt    DateTime  @default(now()) @map("joined_at")
  /// Non-null = participant cancelled during the open window.
  /// Cancelled participants are ignored at expiry.
  cancelledAt DateTime? @map("cancelled_at")

  @@unique([readyCheckId, signupId])
  @@index([signupId])
  @@map("ready_check_participants")
}

// ─────────────────────────────────────────────────────────────
// Run ↔ Event join table — many-to-many (a run can count for
// multiple events, e.g. overlapping time windows)
// ─────────────────────────────────────────────────────────────

model RunEvent {
  id         Int         @id @default(autoincrement())
  runId      Int         @map("run_id")
  run        Run         @relation(fields: [runId], references: [id], onDelete: Cascade)
  eventId    Int         @map("event_id")
  event      Event       @relation("eventRuns", fields: [eventId], references: [id], onDelete: Cascade)
  groupId    Int?        @map("group_id")
  group      EventGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  eventJuice Int         @default(0) @map("event_juice")
  matchedAt  DateTime    @default(now()) @map("matched_at")

  @@unique([runId, eventId])
  @@index([eventId])
  @@index([runId])
  @@map("run_events")
}

// ─────────────────────────────────────────────────────────────
// Teams — persistent pre-made rosters
// ─────────────────────────────────────────────────────────────

model Team {
  id            Int     @id @default(autoincrement())
  name          String
  /// User who created the team — only they can inactivate it
  captainUserId Int     @map("captain_user_id")
  captain       User    @relation("teamsCaptained", fields: [captainUserId], references: [id])
  seasonId      Int     @map("season_id")
  season        Season  @relation(fields: [seasonId], references: [id])
  /// Soft-delete: inactive teams don't appear in signup lists
  active        Boolean @default(true)

  members      TeamMember[]
  eventSignups TeamEventSignup[]

  createdAt DateTime @default(now()) @map("created_at")

  /// Team names are unique per season
  @@unique([seasonId, name])
  @@index([captainUserId])
  @@index([active])
  @@map("teams")
}

model TeamMember {
  id          Int       @id @default(autoincrement())
  teamId      Int       @map("team_id")
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  characterId Int       @map("character_id")
  character   Character @relation(fields: [characterId], references: [id])
  /// Role this member fills on the team: "tank" | "healer" | "dps"
  role        String

  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([teamId, characterId])
  @@index([characterId])
  @@map("team_members")
}

model TeamEventSignup {
  id      Int    @id @default(autoincrement())
  eventId Int    @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId  Int    @map("team_id")
  team    Team   @relation(fields: [teamId], references: [id])
  /// Status: "registered" | "withdrawn" | "no_show" | "completed"
  status  String @default("registered")

  signedUpAt DateTime @default(now()) @map("signed_up_at")

  @@unique([eventId, teamId])
  @@index([eventId])
  @@map("team_event_signups")
}

// ─────────────────────────────────────────────────────────────
// Discord servers — multi-tenant configuration
// ─────────────────────────────────────────────────────────────

model DiscordServer {
  id                   Int     @id @default(autoincrement())
  discordGuildId       String  @unique @map("discord_guild_id")
  guildName            String? @map("guild_name")
  guildIconUrl         String? @map("guild_icon_url")
  installedByDiscordId String? @map("installed_by_discord_id")
  botActive            Boolean @default(true) @map("bot_active")

  eventsChannelId        String? @map("events_channel_id")
  resultsChannelId       String? @map("results_channel_id")
  announcementsChannelId String? @map("announcements_channel_id")
  resultsWebhookUrl      String? @map("results_webhook_url")

  allowPublicEvents Boolean @default(true) @map("allow_public_events")
  timezone          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  admins  DiscordServerAdmin[]
  members DiscordServerMember[]
  events  Event[]

  @@map("discord_servers")
}

model DiscordServerAdmin {
  id         Int           @id @default(autoincrement())
  serverId   Int           @map("server_id")
  server     DiscordServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId     Int           @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String        @default("admin")
  verifiedAt DateTime      @default(now()) @map("verified_at")

  @@unique([serverId, userId])
  @@map("discord_server_admins")
}

model DiscordServerMember {
  id        Int           @id @default(autoincrement())
  serverId  Int           @map("server_id")
  server    DiscordServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPrimary Boolean       @default(false) @map("is_primary")
  joinedAt  DateTime      @default(now()) @map("joined_at")

  @@unique([serverId, userId])
  @@index([userId, isPrimary])
  @@map("discord_server_members")
}

// ─────────────────────────────────────────────────────────────
// Event feedback — reviewer input on event type scoring
// ─────────────────────────────────────────────────────────────

model EventFeedback {
  id                Int      @id @default(autoincrement())
  eventType         String   @map("event_type")
  reviewerName      String   @map("reviewer_name")
  reviewerEmail     String?  @map("reviewer_email")
  scoringPreference String?  @map("scoring_preference")
  scoringRanking    String[] @default([]) @map("scoring_ranking")
  ratings           Json?
  comments          String?
  submittedViaToken String?  @map("submitted_via_token")
  submitterIpHash   String?  @map("submitter_ip_hash")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("event_feedback")
}

// ─────────────────────────────────────────────────────────────
// Endorsements — player-to-player recognition
//
// Scarcity model: earn 1 token per 15,000 Personal Juice, plus one-time
// starter grants (Discord login, companion link). Seasonal tokens reset
// at season rollover; starter tokens persist. One endorsement per
// giver→receiver per run, tied to a specific run, optional note,
// required category.
// ─────────────────────────────────────────────────────────────

enum EndorsementCategory {
  great_tank
  great_healer
  great_dps
  interrupt_master
  dispel_wizard
  cc_master
  cooldown_hero
  affix_slayer
  route_master
  patient_teacher
  calm_under_pressure
  positive_vibes
  shot_caller
  clutch_saviour
  comeback_kid
}

model Endorsement {
  id         Int                 @id @default(autoincrement())
  giverId    Int                 @map("giver_id")
  giver      User                @relation("endorsementsGiven", fields: [giverId], references: [id], onDelete: Cascade)
  receiverId Int                 @map("receiver_id")
  receiver   User                @relation("endorsementsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  /// The specific character the giver played in this run. Scopes
  /// endorsement display to the character who earned it, not every
  /// character on the account.
  giverCharacterId    Int       @map("giver_character_id")
  giverCharacter      Character @relation("endorsementsGivenByCharacter", fields: [giverCharacterId], references: [id], onDelete: Cascade)
  /// The specific character the receiver played in this run. Same rationale.
  receiverCharacterId Int       @map("receiver_character_id")
  receiverCharacter   Character @relation("endorsementsReceivedByCharacter", fields: [receiverCharacterId], references: [id], onDelete: Cascade)
  runId      Int                 @map("run_id")
  run        Run                 @relation(fields: [runId], references: [id], onDelete: Cascade)
  category   EndorsementCategory
  /// Optional note from the giver (encouraged, not required).
  note       String?
  /// Season this endorsement was given in. Preserved for historical views.
  seasonId   Int                 @map("season_id")
  season     Season              @relation(fields: [seasonId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  /// Inverse side for User.favoriteEndorsement (user who has pinned this).
  favoritedByUser User? @relation("favoriteEndorsement")

  /// One endorsement per giver→receiver per run.
  @@unique([giverId, receiverId, runId])
  @@index([receiverId])
  @@index([giverId])
  @@index([runId])
  @@index([receiverId, category])
  @@index([receiverId, seasonId])
  @@index([receiverCharacterId])
  @@index([giverCharacterId])
  @@index([receiverCharacterId, category])
  @@map("endorsements")
}

// ─────────────────────────────────────────────────────────────
// Telemetry — anonymous usage + error events from the companion
// ─────────────────────────────────────────────────────────────

model TelemetryEvent {
  id         BigInt   @id @default(autoincrement())
  /// Anonymous install UUID from the companion's config. Persists
  /// across app restarts on one machine but reveals nothing about
  /// the player. Not a FK — the companion generates it locally.
  installId  String   @map("install_id")
  /// Event name enum from the companion's telemetry.ts module.
  name       String
  /// Companion app version that sent the event, e.g. "0.1.0".
  appVersion String   @map("app_version")
  /// OS + release string, e.g. "win32 10.0.26200".
  platform   String
  /// Free-form JSON bag, caller's responsibility to keep PII-free.
  meta       Json?
  /// Timestamp from the companion (may lag when sent in a batch).
  occurredAt DateTime @map("occurred_at")
  /// Timestamp the API persisted the row.
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([installId, occurredAt])
  @@index([name, occurredAt])
  @@map("telemetry_events")
}

model RunMember {
  id          Int  @id @default(autoincrement())
  runId       Int  @map("run_id")
  /// Nullable: unclaimed characters participate in runs too. Resolved
  /// later when the character gets claimed via /register.
  userId      Int? @map("user_id")
  characterId Int  @map("character_id")

  /// Snapshotted at submission time — a character's class/spec/role may
  /// change later, but the run's record stays accurate.
  classSnapshot String @map("class_snapshot")
  specSnapshot  String @map("spec_snapshot")
  roleSnapshot  String @map("role_snapshot")

  run       Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([runId, characterId])
  @@index([userId])
  @@index([characterId])
  @@map("run_members")
}

// ─────────────────────────────────────────────────────────────
// Combat-log enrichment (Sprint 15)
//
// Populated by the companion app after parsing WoWCombatLog.txt.
// A Run without enrichment is still a valid run — enrichment is additive.
// Designed to collect broadly (even raw COMBATANT_INFO blobs) so Phase E
// event-type work isn't gated on a re-migration.
// ─────────────────────────────────────────────────────────────

enum EnrichmentStatus {
  complete
  partial
  unavailable
}

model RunEnrichment {
  id    Int @id @default(autoincrement())
  runId Int @unique @map("run_id")
  run   Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  status        EnrichmentStatus
  /// When status != complete, short machine-readable reason string
  /// ("log_not_found", "no_matching_segment", "parse_failed", "acl_disabled")
  statusReason  String?          @map("status_reason")
  /// Version of @mplus/combat-log-parser that produced this record
  parserVersion String           @map("parser_version")

  /// Aggregate totals across the M+ segment
  totalDamage         BigInt @default(0) @map("total_damage")
  totalDamageSupport  BigInt @default(0) @map("total_damage_support")
  /// Portion of totalDamage from party pets/guardians/totems (already in totalDamage)
  totalPetDamage      BigInt @default(0) @map("total_pet_damage")
  /// Effective healing (raw heal - overheal - heal-absorbed) + shield absorbs.
  /// Matches Details/Recount's "Healing" column semantics.
  totalHealing        BigInt @default(0) @map("total_healing")
  totalHealingSupport BigInt @default(0) @map("total_healing_support")
  /// Portion of totalHealing from party pets/guardians (already in totalHealing)
  totalPetHealing     BigInt @default(0) @map("total_pet_healing")
  /// Raw overheal total — healing that went to already-topped targets. Tracked
  /// separately so UI can show "1.2M / 300k overheal" and achievements can
  /// compute overheal ratios without a schema migration.
  totalOverhealing    BigInt @default(0) @map("total_overhealing")
  /// Total shield absorbs cast across all party members (split out of
  /// totalHealing so UI can show heal output and shield output separately).
  totalAbsorbProvided BigInt @default(0) @map("total_absorb_provided")
  /// Total damage received across all party members (sum of dest=player damage).
  totalDamageTaken    BigInt @default(0) @map("total_damage_taken")
  totalInterrupts     Int    @default(0) @map("total_interrupts")
  totalDispels        Int    @default(0) @map("total_dispels")
  partyDeaths         Int    @default(0) @map("party_deaths")

  /// Raw trailing fields from CHALLENGE_MODE_END — currently undecoded
  /// (suspected to contain rating-before/after or timer percentile data).
  /// Captured verbatim so we can decode later without a re-migration.
  endTrailingFields Float[] @default([]) @map("end_trailing_fields")

  /// Event-type histogram for the M+ segment, for diagnostics
  eventCountsRaw Json? @map("event_counts_raw")

  /// Width of each player.damageBuckets entry, in ms. Null on pre-timeline rows.
  bucketSizeMs Int? @map("bucket_size_ms")

  /// Absolute timestamp of CHALLENGE_MODE_START — the reference point clients
  /// use to align boss-kill markers onto the damageBuckets timeline.
  /// Null on pre-timeline rows.
  segmentStartedAt DateTime? @map("segment_started_at")

  players    RunEnrichmentPlayer[]
  encounters RunEnrichmentEncounter[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("run_enrichments")
}

model RunEnrichmentPlayer {
  id           Int           @id @default(autoincrement())
  enrichmentId Int           @map("enrichment_id")
  enrichment   RunEnrichment @relation(fields: [enrichmentId], references: [id], onDelete: Cascade)

  /// WoW GUID from log, e.g. "Player-1175-0F92E4A5"
  playerGuid  String     @map("player_guid")
  /// Combined "Name-Realm-US" as it appeared in the log
  playerName  String     @map("player_name")
  /// Auto-detected from COMBATANT_INFO; null if we couldn't match a valid ID
  specId      Int?       @map("spec_id")
  /// Best-effort link to platform character (by name+realm). Null if unmatched.
  characterId Int?       @map("character_id")
  character   Character? @relation(fields: [characterId], references: [id])

  damageDone         BigInt @default(0) @map("damage_done")
  damageDoneSupport  BigInt @default(0) @map("damage_done_support")
  /// Subtotal of damageDone from this player's pets/guardians/totems
  petDamageDone      BigInt @default(0) @map("pet_damage_done")
  /// Effective healing (Details-style): raw heal - overhealing - heal-absorbed,
  /// plus SPELL_ABSORBED credits for shields this player cast.
  healingDone        BigInt @default(0) @map("healing_done")
  healingDoneSupport BigInt @default(0) @map("healing_done_support")
  /// Subtotal of healingDone from this player's pets/guardians
  petHealingDone     BigInt @default(0) @map("pet_healing_done")
  /// Raw overheal — healing that went to fully-topped targets. Displayed
  /// separately so healers can see how much they wasted on GCDs.
  overhealing        BigInt @default(0) @map("overhealing")
  /// Shield absorbs cast by this player (SPELL_ABSORBED where caster=this).
  /// Split out of healingDone so the UI can show heals and absorbs separately.
  absorbProvided     BigInt @default(0) @map("absorb_provided")
  /// Damage actually received (lands in HP). Tank-chart "line 2".
  damageTaken        BigInt @default(0) @map("damage_taken")
  /// Damage directed (post-armor, pre-shield/block/resist). Tank-chart "line 1".
  damageIncoming     BigInt @default(0) @map("damage_incoming")
  /// Self-healing (source = dest). Tank-chart "line 3".
  selfHealing        BigInt @default(0) @map("self_healing")
  /// Avoidance counts — the log doesn't record amount for these.
  parries            Int    @default(0) @map("parries")
  dodges             Int    @default(0) @map("dodges")
  misses             Int    @default(0) @map("misses")
  interrupts         Int    @default(0)
  dispels            Int    @default(0)
  deaths             Int    @default(0)

  /// Per-bucket damage from segment start. Array length = ceil(runDurationMs / bucketSizeMs).
  /// Null on pre-timeline rows; stored as JSON int[] for Postgres.
  damageBuckets   Json?   @map("damage_buckets")
  /// Index into damageBuckets with the highest value (peak damage bucket).
  peakBucketIndex Int?    @map("peak_bucket_index")
  /// Damage in the peak bucket. Peak DPS = peakDamage / (bucketSizeMs / 1000).
  /// Indexed for personal-record queries ("show me my highest peak burst ever").
  peakDamage      BigInt? @map("peak_damage")

  /// Raw healing output per bucket (for the Healing tab chart).
  healingBuckets         Json? @map("healing_buckets")
  /// Shield-absorb output per bucket.
  absorbProvidedBuckets  Json? @map("absorb_provided_buckets")
  /// Damage received per bucket (Tank chart line 2).
  damageTakenBuckets     Json? @map("damage_taken_buckets")
  /// Damage directed per bucket (Tank chart line 1).
  damageIncomingBuckets  Json? @map("damage_incoming_buckets")
  /// Self-heals per bucket (Tank chart line 3).
  selfHealingBuckets     Json? @map("self_healing_buckets")
  /// Cast events for future cooldown-overlay rendering:
  /// [{ spellId: number, offsetMs: number }]
  castEvents             Json? @map("cast_events")

  /// Full COMBATANT_INFO payload — gear, talents, stats, interesting auras.
  /// Stored raw so Phase D/E work can decode additional fields without a
  /// schema migration. Roughly a few KB per player per run.
  combatantInfoRaw Json? @map("combatant_info_raw")

  @@index([enrichmentId])
  @@index([characterId])
  @@index([specId])
  @@index([characterId, peakDamage(sort: Desc)])
  @@map("run_enrichment_players")
}

model RunEnrichmentEncounter {
  id           Int           @id @default(autoincrement())
  enrichmentId Int           @map("enrichment_id")
  enrichment   RunEnrichment @relation(fields: [enrichmentId], references: [id], onDelete: Cascade)

  /// WoW DungeonEncounterID
  encounterId   Int      @map("encounter_id")
  encounterName String   @map("encounter_name")
  /// true = kill, false = wipe
  success       Boolean
  fightTimeMs   Int      @map("fight_time_ms")
  /// Difficulty from ENCOUNTER_START (M+ = 8, delve = 208). Preserved for
  /// diagnostics even though our segment gate should only yield M+ encounters.
  difficultyId  Int      @map("difficulty_id")
  groupSize     Int      @map("group_size")
  startedAt     DateTime @map("started_at")
  /// 0-indexed order this encounter appeared in the run. Distinguishes a
  /// wipe + kill of the same boss.
  sequenceIndex Int      @map("sequence_index")

  @@index([enrichmentId])
  @@index([encounterId])
  @@map("run_enrichment_encounters")
}
