//
// M+ Platform — Prisma schema
//
// Sprint 1 scope: reference data, identity, runs.
// Later sprints will add events, scoring, leaderboards, badges, mentorship.
//
// Naming convention:
//   - snake_case for database columns/tables (@@map, @map)
//   - camelCase for Prisma/TypeScript
//

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Reference data
// ─────────────────────────────────────────────────────────────

model Season {
  id        Int      @id @default(autoincrement())
  /// Short slug, e.g. "midnight-s1"
  slug      String   @unique
  /// Display name, e.g. "Midnight Season 1"
  name      String
  /// WoW patch this season corresponds to, e.g. "12.0.0"
  patch     String
  startsAt  DateTime @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  isActive  Boolean  @default(false) @map("is_active")

  dungeons Dungeon[]
  runs     Run[]
  events   Event[]
  teams    Team[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("seasons")
}

model Dungeon {
  id              Int    @id @default(autoincrement())
  /// WoW internal challenge_mode_id used by C_ChallengeMode API
  challengeModeId Int    @map("challenge_mode_id")
  /// Short slug, e.g. "halls-of-atonement"
  slug            String
  name            String
  /// Par time in seconds — used for on_time calculation and scoring
  parTimeSec      Int    @map("par_time_sec")
  /// Short 3-5 letter abbreviation for compact leaderboard display
  shortCode       String @map("short_code")

  seasonId Int    @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id])

  runs   Run[]
  events Event[]

  @@unique([seasonId, challengeModeId])
  @@unique([seasonId, slug])
  @@map("dungeons")
}

// ─────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────

model User {
  id            Int     @id @default(autoincrement())
  /// Discord user snowflake — primary identity anchor
  discordId     String  @unique @map("discord_id")
  /// Opt-in BattleTag for cross-realm group formation
  battleTag     String? @map("battle_tag")
  /// IANA timezone, e.g. "America/New_York"
  timezone      String?
  /// Mentor program opt-in
  isMentor      Boolean @default(false) @map("is_mentor")
  mentorPoints  Int     @default(0) @map("mentor_points")

  characters      Character[]
  runMembers      RunMember[]
  eventSignups    EventSignup[]
  eventsCreated   Event[]       @relation("eventsCreated")
  teamsCaptained  Team[]        @relation("teamsCaptained")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Character {
  id       Int    @id @default(autoincrement())
  name     String
  /// Realm slug, lowercase-hyphenated, e.g. "area-52"
  realm    String
  /// us, eu, kr, tw, cn
  region   String
  /// WoW class slug, e.g. "shaman". This is permanent for the character —
  /// a shaman is always a shaman. Join with packages/wow-constants to
  /// resolve display name, color, and valid specs/roles.
  class    String
  /// DEFAULT spec. The character's last-known active spec from RaiderIO
  /// or manual refresh. This is just a hint — NOT a constraint. Players
  /// pick their actual role per event at signup time, and the addon
  /// records what was actually played into run_members.spec_snapshot.
  spec     String
  /// DEFAULT role, matching the default spec. Same caveat as `spec`.
  role     String
  /// Latest RaiderIO overall score — refreshed on submission + nightly
  rioScore Int    @default(0) @map("rio_score")
  /// Character portrait URLs (cached from RaiderIO + Blizzard API)
  thumbnailUrl String? @map("thumbnail_url")       // 96x96 avatar (from RaiderIO)
  avatarUrl    String? @map("avatar_url")           // 96x96 from Blizzard CDN
  insetUrl     String? @map("inset_url")            // ~460x460 bust render from Blizzard CDN
  mainRawUrl   String? @map("main_raw_url")         // ~1000x1000 full body transparent PNG

  /// Nullable: an "unclaimed" character exists in our DB because someone
  /// else ran a key with them. When the actual player registers via the
  /// Discord bot, /register will claim the row by setting userId.
  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Timestamp when this character was claimed by a registered user.
  /// NULL until /register links it.
  claimedAt DateTime? @map("claimed_at")

  /// True if this character has submitted at least one run via the
  /// companion app. Used by matchmaking (prefer 1 per group) and as
  /// a subtle tag in embeds/web (⚡ icon).
  hasCompanionApp Boolean @default(false) @map("has_companion_app")

  runMembers   RunMember[]
  eventSignups EventSignup[]
  teamMembers  TeamMember[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// A WoW character is unique by (name, realm, region)
  @@unique([region, realm, name])
  @@index([userId])
  @@map("characters")
}

// ─────────────────────────────────────────────────────────────
// Runs
// ─────────────────────────────────────────────────────────────

enum RunSource {
  addon
  manual
  raiderio
}

model Run {
  id              Int       @id @default(autoincrement())
  dungeonId       Int       @map("dungeon_id")
  seasonId        Int       @map("season_id")
  keystoneLevel   Int       @map("keystone_level")
  completionMs    Int       @map("completion_ms")
  parMs           Int       @map("par_ms")
  onTime          Boolean   @map("on_time")
  /// Keystone upgrade level: 0 (depleted/no upgrade), 1 (+1), 2 (+2), 3 (+3)
  upgrades        Int       @default(0)
  deaths          Int       @default(0)
  timeLostSec     Int       @default(0) @map("time_lost_sec")
  /// Active affix ids from C_MythicPlus.GetCurrentAffixes()
  affixes         Int[]     @default([])
  /// Unix seconds at run completion, from the WoW server
  serverTime      BigInt    @map("server_time")
  /// When the API received the run
  recordedAt      DateTime  @default(now()) @map("recorded_at")
  source          RunSource @default(addon)
  /// True after RaiderIO cross-verification job confirms this run
  verified        Boolean   @default(false)
  /// Dedup hash — see services/run-dedup.ts
  dedupHash       String    @unique @map("dedup_hash")
  /// Computed points — written by scoring service on insert
  points          Int       @default(0)
  /// Dynamic dungeon name from addon (used for auto-discovery)
  dungeonName     String?   @map("dungeon_name")
  /// WoW season ID (dynamic, from C_MythicPlus.GetCurrentSeason)
  wowSeasonId     Int?      @map("wow_season_id")
  /// Submitter's M+ rating before this run
  oldRating       Int?      @map("old_rating")
  /// Submitter's M+ rating after this run
  newRating       Int?      @map("new_rating")
  /// Rating gained from this run
  ratingGained    Int?      @map("rating_gained")
  /// Personal best flags
  isMapRecord     Boolean   @default(false) @map("is_map_record")
  isAffixRecord   Boolean   @default(false) @map("is_affix_record")
  /// Per-player combat stats (JSON: { "Name-realm": { damage, healing, deaths, interrupts, ... } })
  playerStats     Json?     @map("player_stats")
  /// Optional event association
  eventId         Int?       @map("event_id")
  event           Event?     @relation(fields: [eventId], references: [id])
  groupId         Int?       @map("group_id")
  eventGroup      EventGroup? @relation(fields: [groupId], references: [id])

  dungeon Dungeon     @relation(fields: [dungeonId], references: [id])
  season  Season      @relation(fields: [seasonId], references: [id])
  members RunMember[]

  @@index([seasonId, dungeonId, completionMs])
  @@index([seasonId, keystoneLevel])
  @@index([recordedAt])
  @@index([eventId])
  @@map("runs")
}

// ─────────────────────────────────────────────────────────────
// Events — organized M+ competitions
// ─────────────────────────────────────────────────────────────

enum EventStatus {
  draft          // created but not yet visible to players
  open           // accepting signups
  signups_closed // signups locked, groups being formed
  in_progress    // event window is active, runs count
  completed      // event finished, results final
  cancelled      // scrapped before completion
}

enum EventType {
  fastest_clear_race   // All groups, same dungeon, fastest timed clear wins
  speed_sprint         // 30-min window, single attempt per group
  random_draft         // Bot assembles random role-balanced groups
  key_climbing         // Push highest key possible, peak level wins
  marathon             // Most runs in time window, accumulated score wins
  best_average         // Best average score across top N runs
  bracket_tournament   // Single-elimination bracket, head-to-head matchups
}

enum EventMode {
  group   // Individual signup + auto-matchmaking into groups
  team    // Pre-made team signup (no matchmaking)
}

/// How the signup was created
enum SignupSource {
  discord_verified   // user has a linked Character, clicked button
  discord_manual     // user entered character info via modal
  web_oauth          // signed up through website
}

/// Signup intent status
enum SignupStatus {
  confirmed   // definitely attending
  tentative   // interested but unsure
  declined    // not attending (tracked for analytics)
}

model Event {
  id              Int         @id @default(autoincrement())
  name            String
  type            EventType   @default(fastest_clear_race)
  mode            EventMode   @default(group)
  status          EventStatus @default(draft)
  /// Type-specific config (e.g., runsToCount for best_average)
  typeConfig      Json?       @map("type_config")

  /// Discord message ID of the event embed (for in-place updates)
  discordMessageId String?    @map("discord_message_id")
  /// Discord channel ID where the embed was posted
  discordChannelId String?    @map("discord_channel_id")

  /// Which dungeon this event targets (null = any dungeon)
  dungeonId       Int?        @map("dungeon_id")
  dungeon         Dungeon?    @relation(fields: [dungeonId], references: [id])

  seasonId        Int         @map("season_id")
  season          Season      @relation(fields: [seasonId], references: [id])

  /// Discord server this event belongs to (for server-scoped filtering)
  discordGuildId  String?     @map("discord_guild_id")

  /// Key level constraints for the event
  minKeyLevel     Int         @default(2) @map("min_key_level")
  maxKeyLevel     Int         @default(40) @map("max_key_level")

  /// Signup window
  signupOpensAt   DateTime?   @map("signup_opens_at")
  signupClosesAt  DateTime?   @map("signup_closes_at")

  /// Event run window
  startsAt        DateTime    @map("starts_at")
  endsAt          DateTime    @map("ends_at")

  /// Who created this event
  createdByUserId Int         @map("created_by_user_id")
  createdByUser   User        @relation("eventsCreated", fields: [createdByUserId], references: [id])

  /// Optional description / rules text
  description     String?

  signups         EventSignup[]
  groups          EventGroup[]
  teamSignups     TeamEventSignup[]
  runs            Run[]

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@index([seasonId])
  @@index([startsAt])
  @@index([discordGuildId])
  @@map("events")
}

model EventSignup {
  id              Int       @id @default(autoincrement())
  eventId         Int       @map("event_id")
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  /// Nullable: unverified manual signups may not have a User row.
  userId          Int?      @map("user_id")
  user            User?     @relation(fields: [userId], references: [id])

  /// Discord user snowflake of whoever clicked the button / submitted.
  /// Primary identity key for signups — used for dedup since userId can be null.
  discordUserId   String?   @map("discord_user_id")

  characterId     Int       @map("character_id")
  character       Character @relation(fields: [characterId], references: [id])

  /// The role this player wants to fill for this event. Validated
  /// against packages/wow-constants at signup time — a mage can't
  /// sign up as tank.
  rolePreference  String    @map("role_preference") // "tank" | "healer" | "dps"

  /// The spec the player chose for this event. Always user-selected,
  /// never auto-set. Role is derived from spec.
  spec            String?

  /// How this signup was created
  signupSource    SignupSource @default(discord_verified) @map("signup_source")

  /// Signup intent: confirmed, tentative, or declined
  signupStatus    SignupStatus @default(confirmed) @map("signup_status")

  /// Which group was this player assigned to? Null until assign-groups runs.
  groupId         Int?      @map("group_id")
  group           EventGroup? @relation(fields: [groupId], references: [id])

  signedUpAt      DateTime  @default(now()) @map("signed_up_at")

  @@unique([eventId, discordUserId])
  @@index([eventId])
  @@map("event_signups")
}

model EventGroup {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  /// Display name, e.g. "Group Alpha", "Group 1", auto-generated
  name        String

  /// Status: "assigned" | "ready" | "completed"
  status      String    @default("assigned")

  members     EventSignup[]
  runs        Run[]

  assignedAt  DateTime  @default(now()) @map("assigned_at")

  @@index([eventId])
  @@map("event_groups")
}

// ─────────────────────────────────────────────────────────────
// Teams — persistent pre-made rosters
// ─────────────────────────────────────────────────────────────

model Team {
  id            Int          @id @default(autoincrement())
  name          String
  /// User who created the team — only they can inactivate it
  captainUserId Int          @map("captain_user_id")
  captain       User         @relation("teamsCaptained", fields: [captainUserId], references: [id])
  seasonId      Int          @map("season_id")
  season        Season       @relation(fields: [seasonId], references: [id])
  /// Soft-delete: inactive teams don't appear in signup lists
  active        Boolean      @default(true)

  members       TeamMember[]
  eventSignups  TeamEventSignup[]

  createdAt     DateTime     @default(now()) @map("created_at")

  /// Team names are unique per season
  @@unique([seasonId, name])
  @@index([captainUserId])
  @@index([active])
  @@map("teams")
}

model TeamMember {
  id          Int       @id @default(autoincrement())
  teamId      Int       @map("team_id")
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  characterId Int       @map("character_id")
  character   Character @relation(fields: [characterId], references: [id])
  /// Role this member fills on the team: "tank" | "healer" | "dps"
  role        String

  joinedAt    DateTime  @default(now()) @map("joined_at")

  @@unique([teamId, characterId])
  @@index([characterId])
  @@map("team_members")
}

model TeamEventSignup {
  id        Int      @id @default(autoincrement())
  eventId   Int      @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId    Int      @map("team_id")
  team      Team     @relation(fields: [teamId], references: [id])
  /// Status: "registered" | "withdrawn" | "no_show" | "completed"
  status    String   @default("registered")

  signedUpAt DateTime @default(now()) @map("signed_up_at")

  @@unique([eventId, teamId])
  @@index([eventId])
  @@map("team_event_signups")
}

// ─────────────────────────────────────────────────────────────
// Guild configuration — per-Discord-server settings
// ─────────────────────────────────────────────────────────────

model GuildConfig {
  id               Int      @id @default(autoincrement())
  /// Discord guild snowflake — one config per server
  discordGuildId   String   @unique @map("discord_guild_id")
  /// Channel ID where event embeds are posted
  eventsChannelId  String?  @map("events_channel_id")
  /// Cached guild name for display
  guildName        String?  @map("guild_name")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("guild_configs")
}

// ─────────────────────────────────────────────────────────────
// Telemetry — anonymous usage + error events from the companion
// ─────────────────────────────────────────────────────────────

model TelemetryEvent {
  id          BigInt   @id @default(autoincrement())
  /// Anonymous install UUID from the companion's config. Persists
  /// across app restarts on one machine but reveals nothing about
  /// the player. Not a FK — the companion generates it locally.
  installId   String   @map("install_id")
  /// Event name enum from the companion's telemetry.ts module.
  name        String
  /// Companion app version that sent the event, e.g. "0.1.0".
  appVersion  String   @map("app_version")
  /// OS + release string, e.g. "win32 10.0.26200".
  platform    String
  /// Free-form JSON bag, caller's responsibility to keep PII-free.
  meta        Json?
  /// Timestamp from the companion (may lag when sent in a batch).
  occurredAt  DateTime @map("occurred_at")
  /// Timestamp the API persisted the row.
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([installId, occurredAt])
  @@index([name, occurredAt])
  @@map("telemetry_events")
}

model RunMember {
  id          Int  @id @default(autoincrement())
  runId       Int  @map("run_id")
  /// Nullable: unclaimed characters participate in runs too. Resolved
  /// later when the character gets claimed via /register.
  userId      Int? @map("user_id")
  characterId Int  @map("character_id")

  /// Snapshotted at submission time — a character's class/spec/role may
  /// change later, but the run's record stays accurate.
  classSnapshot String @map("class_snapshot")
  specSnapshot  String @map("spec_snapshot")
  roleSnapshot  String @map("role_snapshot")

  run       Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([runId, characterId])
  @@index([userId])
  @@index([characterId])
  @@map("run_members")
}
