{
  "name": "@mplus/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for the M+ Platform — Fastify + Prisma + Redis.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.seed.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.1",
    "@mplus/types": "*",
    "@mplus/wow-constants": "*",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "dotenv-cli": "^8.0.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
