{
  "name": "@mplus/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot for the M+ Platform.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy-commands": "dotenv -e ../../.env -- tsx src/deploy-commands.ts"
  },
  "dependencies": {
    "@mplus/types": "*",
    "@mplus/wow-constants": "*",
    "discord.js": "^14.16.3",
    "ioredis": "^5.10.1",
    "tslib": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
